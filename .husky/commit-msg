#!/usr/bin/env sh
set -e

# Git hooks may run without shell profile; try loading nvm.
if ! command -v npx >/dev/null 2>&1; then
  export NVM_DIR="${NVM_DIR:-$HOME/.nvm}"
  if [ -s "$NVM_DIR/nvm.sh" ]; then
    . "$NVM_DIR/nvm.sh"
    if [ -f ".nvmrc" ]; then
      nvm use >/dev/null 2>&1 || nvm install >/dev/null 2>&1
    fi
  fi
fi

if ! command -v npx >/dev/null 2>&1; then
  echo "commit-msg: npx not found. Load Node.js (nvm) and retry." >&2
  exit 127
fi

npx --no -- commitlint --edit "$1"
