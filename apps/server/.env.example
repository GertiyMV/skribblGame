# Server application environment template

# Адрес, на котором слушает сервер (0.0.0.0 — все интерфейсы)
HOST=0.0.0.0

# Порт HTTP-сервера
PORT=3001

# URL клиентского приложения — используется для CORS
CLIENT_ORIGIN=http://localhost:5173

# URL подключения к Redis
REDIS_URL=redis://localhost:6379

# Окружение запуска: development | production | test
NODE_ENV=development

# Максимальное число создания комнат с одного IP в окне rate limiter
HTTP_CREATE_ROOM_RATE_LIMIT=5

# Доверять заголовку X-Forwarded-For для определения реального IP (включать за proxy/load balancer)
TRUST_PROXY=false

# Включить логирование HTTP-запросов и Socket.IO событий (только в development)
LOG_REQUESTS=true

# Минимальный уровень логирования: trace | debug | info | warn | error | fatal
LOG_LEVEL=info
