{
  "name": "skribbl-game",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/GertiyMV/skribblGame.git"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "check:dist-sync": "node ./scripts/check-dist-sync.mjs",
    "docker:up": "docker compose up",
    "docker:up:build": "docker compose up --build",
    "docker:down": "docker compose down",
    "docker:restart": "docker compose down && docker compose up",
    "docker:build": "docker compose build",
    "docker:logs": "docker compose logs -f",
    "pretest": "npm run check:dist-sync",
    "pretype-check": "npm run build --workspace @skribbl/shared",
    "prebuild": "npm run build --workspace @skribbl/shared",
    "lint": "npm run lint --workspaces --if-present",
    "type-check": "npm run type-check --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "build": "npm run build --workspaces --if-present",
    "commitlint": "commitlint --from=HEAD~1 --to=HEAD",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "prepare": "husky",
    "lint:staged": "lint-staged"
  },
  "engines": {
    "node": "24.14.0"
  },
  "devDependencies": {
    "@commitlint/cli": "20.5.0",
    "@commitlint/config-conventional": "20.5.0",
    "@eslint/js": "9.39.4",
    "@types/node": "25.5.2",
    "@typescript-eslint/eslint-plugin": "8.58.1",
    "@typescript-eslint/parser": "8.58.1",
    "eslint": "9.39.4",
    "eslint-config-prettier": "10.1.8",
    "husky": "9.1.7",
    "lint-staged": "16.4.0",
    "prettier": "3.8.1",
    "typescript": "5.9.3"
  },
  "lint-staged": {
    "*.{js,cjs,mjs,ts}": [
      "node ./node_modules/prettier/bin/prettier.cjs --write",
      "node ./node_modules/eslint/bin/eslint.js --fix"
    ],
    "*.{json,md,yml,yaml}": "node ./node_modules/prettier/bin/prettier.cjs --write"
  }
}
